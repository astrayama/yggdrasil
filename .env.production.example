# ──────────────────────────────────────────────────────────────────────────────
# .env.production (public values only — COMMIT this per branch)
# ──────────────────────────────────────────────────────────────────────────────
# Next.js auto-loads this file during `next build` and bakes NEXT_PUBLIC_* into the
# client bundle. Commit ONLY public values here. NEVER put API keys / private keys
# in this file — runtime secrets are injected by Cloud Run from Secret Manager
# (see cloudrun-service.yaml).
#
# Maintain one per environment branch:
#   develop → dev Firebase project (yggdrasil-dev)
#   main    → prod Firebase project (yggdrasil-prod)

# ─── Firebase (Client SDK) — public, safe to commit ──────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
NODE_ENV=production

# ──────────────────────────────────────────────────────────────────────────────
# RUNTIME SECRETS — DO NOT put them here. They live in Secret Manager and are
# mounted as env vars on Cloud Run (cloudrun-service.yaml). Listed for reference:
# ──────────────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY                 → secret: gemini-api-key
# FIREBASE_ADMIN_PROJECT_ID      → set inline in cloudrun-service.yaml (== project)
# FIREBASE_ADMIN_CLIENT_EMAIL    → secret: firebase-admin-client-email
# FIREBASE_ADMIN_PRIVATE_KEY     → secret: firebase-admin-private-key  (optional; ADC used if absent)
# GA4_API_SECRET                 → secret: ga4-api-secret
# STRIPE_SECRET_KEY              → secret: stripe-secret-key
# STRIPE_PUBLISHABLE_KEY         → secret: stripe-publishable-key
# STRIPE_WEBHOOK_SECRET          → secret: stripe-webhook-secret  (functions only)
